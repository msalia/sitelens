# Safe local-development defaults. Override in production via Dokploy env vars.

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=sitelens
DATABASE_URL=postgresql://postgres:postgres@db:5432/sitelens

# Service wiring (compose-internal hostnames)
API_INTERNAL_URL=http://api:4000

# Shared Redis for the auth rate limiter (holds the limit across API instances).
# Empty/unset → in-process limiter.
REDIS_URL=redis://redis:6379

# Auth (override JWT_SECRET in production; COOKIE_SECURE=true behind HTTPS)
JWT_SECRET=dev-insecure-secret-change-me
COOKIE_SECURE=false

# File storage (local volume in v1)
STORAGE_DIR=/data/uploads

# Local host ports (used by docker-compose.override.yml)
WEB_PORT=3000
API_PORT=4000

# Shared Cesium Ion token served by the API to all clients (enables World
# Terrain). Empty → flat ellipsoid. Set the real token in the Dokploy env.
CESIUM_ION_TOKEN=

# Optional: auth signup/login attempts per IP per minute (default 10).
# AUTH_RATE_LIMIT_MAX=10

# OpenTopography DEM API key (get one at https://opentopography.org). Used by /api/dem.
OPENTOPO_API_KEY=
